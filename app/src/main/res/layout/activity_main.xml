<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎯 Darts Checkout"
        android:textSize="28sp"
        android:textColor="#e94560"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/etScore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Unesi rezultat (2-170)"
        android:inputType="number"
        android:textSize="18sp"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="24dp"
        android:layout_marginRight="24dp"/>

    <Button
        android:id="@+id/btnCalculate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="IZRAČUNAJ"
        android:backgroundTint="@color/accent"
        android:layout_marginTop="12dp"
        android:layout_marginLeft="24dp"
        android:layout_marginRight="24dp"/>



    <TextView
        android:id="@+id/tvResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#E94550"
        android:textSize="16sp"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"/>

    <!-- Sve strelice na istom mjestu u FrameLayoutu -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">

        <!-- Dart 1 -->
        <LinearLayout
            android:id="@+id/llCheckboxes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginLeft="24dp">

                <EditText
                    android:id="@+id/etdart1"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:hint="Prva strelica"
                    android:inputType="number"
                    android:textSize="18sp"/>

                <CheckBox
                    android:id="@+id/cbDouble"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="D"
                    android:layout_marginLeft="12dp"/>

                <CheckBox
                    android:id="@+id/cbTriple"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="T"
                    android:layout_marginLeft="12dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnDart1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PRVA STRELICA"
                android:backgroundTint="#e94560"
                android:layout_marginTop="8dp"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp"/>

        </LinearLayout>

        <!-- Dart 2 -->
        <LinearLayout
            android:id="@+id/llDart2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginLeft="24dp">

                <EditText
                    android:id="@+id/etdart2"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:hint="Druga strelica"
                    android:inputType="number"
                    android:textSize="18sp"/>

                <CheckBox
                    android:id="@+id/cbDouble2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="D"
                    android:layout_marginLeft="12dp"/>

                <CheckBox
                    android:id="@+id/cbTriple2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="T"
                    android:layout_marginLeft="12dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnDart2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IZRAČUNAJ"
                android:backgroundTint="#e94560"
                android:layout_marginTop="8dp"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp"/>

        </LinearLayout>

        <!-- Dart 3 -->
        <LinearLayout
            android:id="@+id/llDart3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginLeft="24dp">

                <EditText
                    android:id="@+id/etdart3"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:hint="Treća strelica"
                    android:inputType="number"
                    android:textSize="18sp"/>

                <CheckBox
                    android:id="@+id/cbDouble3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="D"
                    android:layout_marginLeft="12dp"/>

                <CheckBox
                    android:id="@+id/cbTriple3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="T"
                    android:layout_marginLeft="12dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnDart3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IZRAČUNAJ"
                android:backgroundTint="#e94560"
                android:layout_marginTop="8dp"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp"/>

        </LinearLayout>

    </FrameLayout>
    <Button
        android:id="@+id/btnHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="POVIJEST"
        android:backgroundTint="#16213e"
        android:layout_marginLeft="24dp"
        android:layout_marginRight="24dp"/>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:name="com.example.checkoutcal.CheckoutFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"/>

    <LinearLayout
        android:layout_width="200dp"
        android:layout_height="match_parent"
        android:layout_gravity="center_horizontal">
    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"

        android:src="@drawable/target"/>
    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:src="@drawable/dart"/>

    </LinearLayout>

</LinearLayout>